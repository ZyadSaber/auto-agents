# ══════════════════════════════════════════════════════════════
#  ENVIRONMENT CONFIGURATION TEMPLATE
#  Copy to .env and fill in your values. Never commit .env.
# ══════════════════════════════════════════════════════════════

# ── Branding (each self-hosted customer overrides these) ───────
SYSTEM_NAME=AI Customer Service
COMPANY_NAME=
SYSTEM_TAGLINE=Powered by local AI

# ══════════════════════════════════════════════════════════════
#  Original settings below
# ══════════════════════════════════════════════════════════════

# ------------------------------------------------------------------------------
# 🔐 AUTHENTICATION & SECURITY
# ------------------------------------------------------------------------------

# Random string used to sign JWT tokens for dashboard login
JWT_SECRET=replace-with-a-very-long-random-string

# Secret key for agents to talk to each other (must match across all services)
AGENT_API_KEY=cs-internal-agent-key-change-this

# Comma-separated list of allowed origins for CORS (no trailing slashes)
# Set this to your server's IP address(es) — both LAN and loopback recommended
# If you access the dashboard on a specific port, include the port too
# e.g. http://10.0.0.11,http://127.0.0.1,http://10.0.0.11:3001
# Future: setup wizard (Phase 7) will auto-detect and fill this on first run
ALLOWED_ORIGINS=http://127.0.0.1,http://10.0.0.11

# --- Initial Admin Setup (Created on first run) ---
# ------------------------------------------------------------------------------

# Username for the Super Admin account
INITIAL_ADMIN_USERNAME=admin

# Password for the Super Admin account
INITIAL_ADMIN_PASSWORD=your-secure-password

# ------------------------------------------------------------------------------
# 🤖 AI MODEL DEFAULTS (Server-Specific)
# ------------------------------------------------------------------------------

# Default model used for general tasks
CHAT_MODEL=aya-expanse:32b

# Model optimized for Arabic (Used when 'Smart Routing' detects Arabic)
ARABIC_MODEL=qwen2.5:72b

# Model optimized for English (Used when 'Smart Routing' detects English)
ENGLISH_MODEL=llama3.3:70b

# ------------------------------------------------------------------------------
# 📬 MESSAGING & INTEGRATIONS
# ------------------------------------------------------------------------------

# Your primary Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZ

# Bot 2 — customer-facing Telegram bot token from @BotFather
SECOND_TELEGRAM_BOT_TOKEN=

# Bot 1 — Telegram group/channel ID for proactive push notifications (internal staff)
# Get this by adding @userinfobot to your group, or use a negative ID for groups
INTERNAL_CHANNEL_ID=

# ClickUp API Key for automated task/ticket reporting
CLICKUP_API_KEY=pk_12345_your_actual_key

# ------------------------------------------------------------------------------
# ⚙️ SYSTEM SETTINGS
# ------------------------------------------------------------------------------

# Port where the main Dashboard UI will be accessible
DASHBOARD_PORT=3001

# Refresh interval (ms) for the monitor dashboard (e.g., 5000 = 5 seconds)
MONITOR_REFRESH_INTERVAL=5000

# ------------------------------------------------------------------------------
# 🖥️ RESOURCE LIMITS (CPU cores & RAM per service)
# ------------------------------------------------------------------------------
# Set to 0 or leave empty to run without limits (uses all available host resources)
# Set to a value to cap usage — useful when sharing the server with other workloads
#
# CPU format : decimal cores  (e.g. 4, 1.5)
# Memory format: number + unit (e.g. 8G, 512M) — or 0 for no limit
#
# ── Ollama (LLM runtime — needs the most resources) ──────────────────────────
OLLAMA_CPU_LIMIT=0
OLLAMA_MEM_LIMIT=0
OLLAMA_CPU_RESERVE=0
OLLAMA_MEM_RESERVE=0

# Ollama inference tuning
# OLLAMA_NUM_THREAD    — number of CPU threads for inference (default: 8, set to your core count)
# OLLAMA_NUM_PARALLEL  — concurrent inference sessions (default: 2, lower = more RAM per session)
# OLLAMA_MAX_LOADED_MODELS — models kept hot in RAM (default: 2)
OLLAMA_NUM_THREAD=8
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=2

# ── ChromaDB (vector database) ────────────────────────────────────────────────
CHROMA_CPU_LIMIT=0
CHROMA_MEM_LIMIT=0
CHROMA_CPU_RESERVE=0
CHROMA_MEM_RESERVE=0

# ── Docs Agent (RAG + embeddings) ─────────────────────────────────────────────
DOCS_CPU_LIMIT=0
DOCS_MEM_LIMIT=0
DOCS_CPU_RESERVE=0
DOCS_MEM_RESERVE=0

# ── General Agent (conversation history) ─────────────────────────────────────
GENERAL_CPU_LIMIT=0
GENERAL_MEM_LIMIT=0
GENERAL_CPU_RESERVE=0
GENERAL_MEM_RESERVE=0

# ── Channel Bridge (WhatsApp + Telegram) ──────────────────────────────────────
BRIDGE_CPU_LIMIT=0
BRIDGE_MEM_LIMIT=0
BRIDGE_CPU_RESERVE=0
BRIDGE_MEM_RESERVE=0

# ── Nginx (reverse proxy) ─────────────────────────────────────────────────────
NGINX_CPU_LIMIT=0
NGINX_MEM_LIMIT=0
NGINX_CPU_RESERVE=0
NGINX_MEM_RESERVE=0
