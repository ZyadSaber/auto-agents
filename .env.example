# ================================================================
#  AI Customer Service System — Environment Variables
#  Copy this file to .env and fill in your values
# ================================================================

# ── Model ─────────────────────────────────────────────────────────
#   aya-expanse:32b  →  ~22 GB RAM (Q4) — best Arabic + English
#   aya-expanse:8b   →  ~6 GB  RAM (Q4) — lighter, faster fallback
#
CHAT_MODEL=aya-expanse:32b

# ── Internal agent API key ────────────────────────────────────────
# All services share this key — change it to something secret!
# Must be the same value everywhere.
AGENT_API_KEY=cs-internal-agent-key-CHANGE-ME

# ── Rate limiting ─────────────────────────────────────────────────
# Max questions per user per minute
RATE_LIMIT_RPM=20

# ── AnythingLLM auth ──────────────────────────────────────────────
ANYTHINGLLM_AUTH=anythingllm-admin-secret-CHANGE-ME
JWT_SECRET=cs-jwt-secret-CHANGE-ME

# ── Telegram ──────────────────────────────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ── WhatsApp ──────────────────────────────────────────────────────
# Scan QR at http://YOUR_SERVER/qr after startup
ENABLE_WHATSAPP=true

# ── Enable/disable channels ───────────────────────────────────────
ENABLE_TELEGRAM=true
