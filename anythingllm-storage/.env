# AnythingLLM Configuration
# This file is mounted into the AnythingLLM container

SERVER_PORT=3001
STORAGE_DIR=/app/server/storage

# LLM: Ollama
LLM_PROVIDER=ollama
OLLAMA_BASE_PATH=http://ollama:11434
OLLAMA_MODEL_PREF=aya-expanse:8b
OLLAMA_MODEL_TOKEN_LIMIT=4096

# Embeddings: Ollama
EMBEDDING_ENGINE=ollama
EMBEDDING_BASE_PATH=http://ollama:11434
EMBEDDING_MODEL_PREF=nomic-embed-text
EMBEDDING_MODEL_MAX_CHUNK_LENGTH=8192

# Vector DB: ChromaDB
VECTOR_DB=chroma
CHROMA_ENDPOINT=http://chromadb:8000
CHROMA_API_HEADER=X-Chroma-Token
CHROMA_API_KEY=cs-chroma-secret-token

# Auth
AUTH_TOKEN=anythingllm-admin-secret
JWT_SECRET=cs-jwt-secret-change-me-in-production

# Disable telemetry
DISABLE_TELEMETRY=true

# Custom agents (accessible from within AnythingLLM)
# Staff can call these via the AnythingLLM API connector
DOCS_AGENT_API=http://docs-agent:8100
GENERAL_AGENT_API=http://general-agent:8200
